# 通用必填配置（与具体 provider 无关）

# NapCat 登录的机器人 QQ 号
QQ_ACCOUNT=你的机器人QQ号

# 允许使用机器人的 QQ 用户白名单，多个用英文逗号分隔
AUTHORIZED_USER_IDS=你的QQ号,另一个授权QQ号

# DeepSeek API：用于 /ai 的 LLM 精排
DEEPSEEK_API_KEY=sk-your-deepseek-api-key


# 按所选 provider 必填的凭证

# Embedding 引擎选择：openai（默认，OpenAI 兼容 API）/ google
EMBEDDING_PROVIDER=openai

# 当 EMBEDDING_PROVIDER=openai（默认）时必填：
# 任意 OpenAI 兼容 Embedding 服务的 API Key（示例默认使用 GLM）
OPENAI_EMBEDDING_API_KEY=sk-your-api-key

# 当 EMBEDDING_PROVIDER=google 时必填：
GOOGLE_API_KEY=
GOOGLE_EMBEDDING_MODEL=gemini-embedding-001
# GOOGLE_BASE_URL=  # 可选，Google GenAI API 代理地址

# OCR 引擎选择：rapidocr（默认，本地 ONNX 推理）/ paddle / deepseek
OCR_PROVIDER=rapidocr

# 当 OCR_PROVIDER=paddle 时必填：
# 百度 PaddleOCR 云 API Access Token
PADDLEOCR_ACCESS_TOKEN=

# 当 OCR_PROVIDER=deepseek 时必填：
# 任意 OpenAI 兼容视觉 OCR 服务的 API Key
OPENAI_OCR_API_KEY=sk-your-api-key


# 可选配置（endpoint、模型名、并发、超时等）

# NapCat WebUI 登录密钥：首次启动自动生成，修改后需删除 napcat/config/webui.json 并重启
NAPCAT_WEBUI_TOKEN=memepilot

# Bot 监听地址：NapCat 通过反向 WebSocket 连接该地址
BOT_HOST=0.0.0.0
BOT_PORT=8080

# DeepSeek OpenAI-compatible endpoint
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# OpenAI 兼容 Embedding endpoint（当 EMBEDDING_PROVIDER=openai 时生效）
OPENAI_EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
OPENAI_EMBEDDING_MODEL=embedding-3

# OpenAI 兼容 OCR endpoint（当 OCR_PROVIDER=deepseek 时生效）
OPENAI_OCR_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_OCR_MODEL=deepseek-ai/DeepSeek-OCR

# PaddleOCR API 地址（可选，默认使用 SDK 内置地址）
# PADDLEOCR_BASE_URL=https://paddleocr.aistudio-app.com

# OCR 文本置信度阈值（PaddleOCR 与 RapidOCR 共用）
OCR_TEXT_SCORE=0.9

# 读锁等待超时：search/ai_match 在写入期间阻塞等待的最大时间
READ_LOCK_TIMEOUT=00:00:30

# /add 命令用户等待超时：从用户发送图片到收到结果的等待上限
ADD_COMMAND_TIMEOUT=00:01:00

# 会话超时：/add 等待用户发送图片的时限，超时后会话自动过期
SESSION_EXPIRE_TIMEOUT=00:01:00

# Embedding API 并发上限（EMBEDDING_CONCURRENCY）
EMBEDDING_CONCURRENCY=5

# OCR API 并发上限（PaddleOCR / OpenAI 兼容 OCR 均适用；RapidOCR 本地推理也受其限制）
OCR_CONCURRENCY=5

# LLM 精排并发上限（DeepSeek 模型调用并发数）
RERANK_CONCURRENCY=5

# 图片压缩并发上限（限制 asyncio.to_thread 调用 Pillow 的线程并发数）
COMPRESS_CONCURRENCY=5

# 必填配置

# NapCat 登录的机器人 QQ 号
QQ_ACCOUNT=你的机器人QQ号

# 允许使用机器人的 QQ 用户白名单，多个用英文逗号分隔
AUTHORIZED_USER_IDS=你的QQ号,另一个授权QQ号

# DeepSeek API：用于 /ai 的 LLM 精排
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Embedding API：用于生成向量（支持任何 OpenAI 兼容服务）
EMBEDDING_API_KEY=sk-your-api-key

# SiliconFlow API：用于 OCR
SILICONFLOW_API_KEY=sk-your-siliconflow-api-key

# 可选配置

# NapCat WebUI 登录密钥：首次启动自动生成，修改后需删除 napcat/config/webui.json 并重启
NAPCAT_WEBUI_TOKEN=memepilot

# Bot 监听地址：NapCat 通过反向 WebSocket 连接该地址
BOT_HOST=0.0.0.0
BOT_PORT=8080

# DeepSeek OpenAI-compatible endpoint
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Embedding endpoint（支持任何 OpenAI 兼容服务，向量维度 1024）
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3

# SiliconFlow API（用于 OCR）
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_OCR_MODEL=deepseek-ai/DeepSeek-OCR

# 索引同步并发上限：启动同步与 /refresh 处理新增图片时，同时发起的
# OCR/embedding 请求数。避免一次性大量请求触发 SiliconFlow 限流。
SYNC_CONCURRENCY=5

# 读锁等待超时：search/ai_match 在写入期间阻塞等待的最大时间
READ_LOCK_TIMEOUT=00:00:30

# /add 命令用户等待超时：从用户发送图片到收到结果的等待上限
ADD_COMMAND_TIMEOUT=00:01:00

# 会话超时：/add 等待用户发送图片的时限，超时后会话自动过期
SESSION_EXPIRE_TIMEOUT=00:01:00

# OCR 引擎选择：paddle（默认）或 deepseek
OCR_PROVIDER=paddle

# PaddleOCR 官方云 API Access Token（当 OCR_PROVIDER=paddle 时必填）
PADDLEOCR_ACCESS_TOKEN=

# PaddleOCR API 地址（可选，默认使用 SDK 内置地址）
# PADDLEOCR_BASE_URL=https://aip.baidubce.com

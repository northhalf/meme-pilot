# 必填配置

# NapCat 登录的机器人 QQ 号
QQ_ACCOUNT=你的机器人QQ号

# 允许使用机器人的 QQ 用户白名单，多个用英文逗号分隔
AUTHORIZED_USER_IDS=你的QQ号,另一个授权QQ号

# DeepSeek API：用于 /ai 的 LLM 精排
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# SiliconFlow API：用于生成 embedding
SILICONFLOW_API_KEY=sk-your-siliconflow-api-key

# 可选配置

# Bot 监听地址：NapCat 通过反向 WebSocket 连接该地址
BOT_HOST=0.0.0.0
BOT_PORT=8080

# DeepSeek OpenAI-compatible endpoint
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# SiliconFlow Embedding endpoint
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B

# 日志级别
LOG_LEVEL=INFO
